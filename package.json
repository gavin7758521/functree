{
  "name": "functree",
  "version": "0.2.0",
  "private": true,
  "description": "面向 AI 协作的软件功能知识库服务端。",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @functree/domain build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev": "pnpm --filter @functree/server dev",
    "dev:web": "pnpm --filter @functree/web dev",
    "start": "pnpm --filter @functree/server start",
    "mcp": "pnpm --filter @gavin7758521/functree-mcp mcp",
    "mcp:version": "node scripts/bump-mcp-version.mjs",
    "mcp:version:check": "pnpm --filter @gavin7758521/functree-mcp check:version",
    "mcp:pack:dry-run": "pnpm --filter @gavin7758521/functree-mcp pack:dry-run",
    "mcp:publish:dry-run": "pnpm --filter @gavin7758521/functree-mcp publish:dry-run"
  },
  "keywords": [
    "功能知识库",
    "MCP",
    "AI工具",
    "研发协作",
    "功能对齐"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
